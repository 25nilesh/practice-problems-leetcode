class Solution {
public:
    string mapWordWeights(vector<string>& words, vector<int>& weights) {

        vector<char> reverse;
        for(int i=122;i>=97;i--){
            reverse.push_back((char)i);
        }
        string result="";
        for(auto word: words){
            int wt=0;
            for(char ch: word){
                wt+=weights[ch-97];
            }
            wt=wt%26;
            result+=reverse[wt];
        }
        return result;
    }
};
