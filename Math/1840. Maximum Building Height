class Solution {
public:
    int maxBuilding(int n, vector<vector<int>>& restrictions) {
        restrictions.push_back({1,0});
        restrictions.push_back({n,n-1});

        sort(begin(restrictions),end(restrictions));
        int m=restrictions.size();

        // traversing left to right 
        for(int i=1;i<m;i++){
            int diff=restrictions[i][0]-restrictions[i-1][0];
            restrictions[i][1]=min(restrictions[i][1],restrictions[i-1][1]+diff);
        }

        // traversing right to left
        for(int i=m-2;i>=0;i--){
            int diff=restrictions[i+1][0]-restrictions[i][0];
            restrictions[i][1]=min(restrictions[i][1],restrictions[i+1][1]+diff);
        }
        int peak,maxi=0;
        for(int i=1;i<m;i++){
            int h2=restrictions[i][1];
            int h1=restrictions[i-1][1];

            peak=max(h1,h2)+((restrictions[i][0]-restrictions[i-1][0])-abs(h2-h1))/2;
            maxi=max(maxi,peak);
        }
        return maxi;
    }
};
