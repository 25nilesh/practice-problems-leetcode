class Solution {
public:
    int maxIceCream(vector<int>& costs, int coins) {
        sort(costs.begin(),costs.end());
        int result=0;
        for(int cost: costs){
            if(cost>coins){
                break;
            }
            coins-=cost;
            result++;
        }   
        return result;


        // approach 2 using O(n) space and O(n) time
        int n=costs.size();
        int result=0;
        vector<int> maxCost(100005,0);
        for(int cost: costs){
            maxCost[cost]++;
        }
        for(int i=1;i<maxCost.size();i++){
            if(maxCost[i]==0) continue;
            if(i>coins) continue;
            int req=coins/i;
            int use=min(req,maxCost[i]);
            result+=use;
            coins-=i*use;
        }
        return result;
    }
};
