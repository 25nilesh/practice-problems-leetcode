#include<bits/stdc++.h>
#define ll long long int 
using namespace std;
vector<vector<ll>> dp;
ll Ldeque(vector<int>& arr,int i,int j){
    if(i==j) return arr[i];
    if(dp[i][j]!=-1) return dp[i][j];
    ll ans=0;
    ans+=max(arr[i]-Ldeque(arr,i+1,j), arr[j]-Ldeque(arr,i,j-1));
    return dp[i][j]=ans;

}
int main(){
    int n;
    cin>>n;
    vector<int> arr(n);
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    dp.resize(3001,vector<ll>(3001,-1));
    ll ans=Ldeque(arr,0,n-1);
    cout<<ans<<"\n";
}
