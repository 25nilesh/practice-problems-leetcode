class Solution {
public:
    int largestAltitude(vector<int>& gain) {
        int maxAltitude=gain[0];
        int curr=gain[0];
        for(int i=1;i<gain.size();i++){
            curr+=gain[i];
            maxAltitude=max(maxAltitude,curr);
        }
        return maxAltitude>0?maxAltitude:0;
    }
};
