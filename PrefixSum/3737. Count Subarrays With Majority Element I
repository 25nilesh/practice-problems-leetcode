        //             if(nums[k]==target){
        //                 count++;
        //             }
        //         }
        //         if(count>(j-i+1)/2) result++;
        //     }
        // }
        // return result;


        // simplified brute-force t.c = O(n*n) -> acceptable
        // for(int i=0;i<n;i++){
        //     int count=0;
        //     for(int j=i;j<n;j++){
        //         count+=(nums[j]==target)?1:0;
        //         if(count>(j-i+1)/2) result++;
        //     }
        // }
