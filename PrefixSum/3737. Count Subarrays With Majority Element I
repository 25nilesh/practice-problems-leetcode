        //         count+=(nums[j]==target)?1:-1;
        //         if(count>0) result++;
        //     }
        // }
        // return result;


        // using prefix sum or cummulative sum approach
        for(int i=0;i<n;i++){
            if(nums[i]==target) nums[i]=1;
            else nums[i]=-1;
        }
        for(int i=1;i<n;i++){
            nums[i]+=nums[i-1];
        }
        long long ans=0;
        for(int i=0;i<n;i++){
            for(int j=i;j<n;j++){
                int sum=nums[j]-((i>0) ? nums[i-1]:0);
                if(sum>0) ans++;
            }
        }
        return ans;
    }
